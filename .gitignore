# ============================================================
# AgentWarRoom — Monorepo .gitignore
# ============================================================

# ─── Dependencias ───────────────────────────────────────────
node_modules/
.pnp
.pnp.js
.yarn/install-state.gz

# ─── Next.js (M1) ───────────────────────────────────────────
.next/
out/
.vercel

# ─── Build outputs (M2/M3) ──────────────────────────────────
# dist/ se commitea intencionalmente en M3 para consumo sin build
# Descomenta si prefieres no subir los dist:
# agentstudio-board/dist/
# agentstudio-actions/dist/

# TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo

# ─── Variables de entorno ────────────────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local

# ─── Logs ────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ─── Herramientas de desarrollo ──────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Playwright / Testing ────────────────────────────────────
.playwright-mcp/
playwright-report/
test-results/

# ─── Claude Code / AI tools ──────────────────────────────────
.claude/
.superpowers/
.gemini/

# ─── Screenshots / debug images (raíz) ──────────────────────
agent-response.png
app-chat.png
app-load.png
app-v2.png
app-v3.png
app-v4.png
app-working.png
final-test.png
fixed-component.png
full-component.png
wide.png

# ─── OS / Sistema ────────────────────────────────────────────
*.tmp
*.temp
.cache/
