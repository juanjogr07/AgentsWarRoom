{
  "name": "@agentstudio/board",
  "version": "0.1.0",
  "private": false,
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --external react --external react-dom --external recharts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --external react --external react-dom --external recharts --watch",
    "type-check": "tsc --noEmit",
    "preview": "vite preview/"
  },
  "dependencies": {},
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "recharts": "^2.12.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.4",
    "tsup": "^8.3.0",
    "typescript": "^5",
    "vite": "^6.3.5"
  }
}
